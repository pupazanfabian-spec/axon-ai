// 🔥 AXON AI ENGINE — ALL IN ONE (OpenAI + Gemini)
// include: testKey, detectare, auto-switch, fallback, request real

type Provider = 'openai' | 'gemini';

// =========================
// 🧠 DETECTARE PROVIDER
// =========================
export function detectProvider(key: string): Provider | null {
  if (key.startsWith('sk-')) return 'openai';
  if (key.startsWith('AIza')) return 'gemini';
  return null;
}

// =========================
// 🧠 AUTO SELECT PROVIDER
// =========================
export function chooseProvider(prompt: string): Provider {
  const complexWords = ['cod', 'programare', 'debug', 'analiza', 'erori'];

  const isComplex = complexWords.some(w =>
    prompt.toLowerCase().includes(w)
  );

  return isComplex ? 'openai' : 'gemini';
}

// =========================
// 🔐 TEST CHEIE REAL
// =========================
export async function testKey(provider: Provider, key: string): Promise<boolean> {
  try {
    if (provider === 'openai') {
      const res = await fetch('https://api.openai.com/v1/chat/completions', {
        method: 'POST',
        headers: {
          Authorization: `Bearer ${key}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          model: 'gpt-4o-mini',
          messages: [{ role: 'user', content: 'Say OK' }],
          max_tokens: 5,
        }),
      });

      return res.ok;
    }

    if (provider === 'gemini') {
      const res = await fetch(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${key}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{ parts: [{ text: 'Say OK' }] }],
          }),
        }
      );

      return res.ok;
    }

    return false;
  } catch (err) {
    console.log('TestKey error:', err);
    return false;
  }
}

// =========================
// 🤖 CALL OPENAI
// =========================
async function callOpenAI(prompt: string, key: string): Promise<string> {
  const res = await fetch('https://api.openai.com/v1/chat/completions', {
    method: 'POST',
    headers: {
      Authorization: `Bearer ${key}`,
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({
      model: 'gpt-4o-mini',
      messages: [{ role: 'user', content: prompt }],
    }),
  });

  if (!res.ok) throw new Error('OpenAI error');

  const data = await res.json();
  return data.choices?.[0]?.message?.content || 'No response';
}

// =========================
// 🤖 CALL GEMINI
// =========================
async function callGemini(prompt: string, key: string): Promise<string> {
  const res = await fetch(
    `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${key}`,
    {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        contents: [{ parts: [{ text: prompt }] }],
      }),
    }
  );

  if (!res.ok) throw new Error('Gemini error');

  const data = await res.json();
  return data?.candidates?.[0]?.content?.parts?.[0]?.text || 'No response';
}

// =========================
// 🔥 MAIN AI FUNCTION
// =========================
export async function askAI({
  prompt,
  openaiKey,
  geminiKey,
}: {
  prompt: string;
  openaiKey?: string;
  geminiKey?: string;
}): Promise<string> {

  const preferred = chooseProvider(prompt);

  try {
    // 🔵 încearcă OpenAI
    if (preferred === 'openai' && openaiKey) {
      return await callOpenAI(prompt, openaiKey);
    }

    // 🟡 încearcă Gemini
    if (preferred === 'gemini' && geminiKey) {
      return await callGemini(prompt, geminiKey);
    }

    // fallback manual
    if (openaiKey) return await callOpenAI(prompt, openaiKey);
    if (geminiKey) return await callGemini(prompt, geminiKey);

    throw new Error('No API key available');

  } catch (err) {
    console.log('Primary failed, trying fallback...');

    // 🔁 fallback automat
    try {
      if (preferred === 'openai' && geminiKey) {
        return await callGemini(prompt, geminiKey);
      }
      if (preferred === 'gemini' && openaiKey) {
        return await callOpenAI(prompt, openaiKey);
      }
    } catch (fallbackErr) {
      console.log('Fallback failed:', fallbackErr);
    }

    return '❌ Eroare AI (verifică cheia sau conexiunea)';
  }
}
