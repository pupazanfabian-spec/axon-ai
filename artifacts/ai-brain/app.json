{
  "expo": {
    "name": "Axon AI",
    "slug": "ai-brain",
    "version": "3.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ai-brain",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.axon.ai",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Axon poate citi fișiere și imagini din galerie.",
        "NSCameraUsageDescription": "Axon poate fotografia ecranul sau obiecte pentru a citi și memora text.",
        "NSDocumentsFolderUsageDescription": "Axon stochează modelul AI local."
      }
    },
    "android": {
      "backgroundColor": "#0A0A0F",
      "package": "com.axon.ai",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ],
      "usesCleartextTraffic": false
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "594c734d-da36-4933-8712-146d347f5e00"
      }
    },
    "owner": "pfabianq",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/594c734d-da36-4933-8712-146d347f5e00"
    }
  }
}
